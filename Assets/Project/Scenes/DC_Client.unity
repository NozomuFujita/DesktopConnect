--- !u!114 &1239196569
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1239196568}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: caf5982225efbe3499d51d5f0648b311, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  apiKey: 
  systemPrompt: "\u4E0E\u3048\u3089\u308C\u305F\u30E1\u30C3\u30BB\u30FC\u30B8\u306E\u611F\u60C5\u3068\u3001\u305D\u306E\u611F\u60C5\u306E\u5F37\u3055\u3092\u5206\u6790\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u5FC5\u305A\u4E8B\u524D\u306B\u30E1\u30C3\u30BB\u30FC\u30B8\u5185\u5BB9\u304B\u3089\u3069\u306E\u611F\u60C5\u304C\u6700\u3082\u5F53\u3066\u306F\u307E\u308B\u304B\u3001\u304A\u3088\u3073\u305D\u306E\u5F37\u5EA6\u3092\u3069\u306E\u3088\u3046\u306B\u5224\u65AD\u3057\u305F\u304B\u3001\u5185\u90E8\u7684\u306B\u8003\u3048\u305F\u3046\u3048\u3067\u3001\u6700\u5F8C\u306BJSON\u5F62\u5F0F\u3067\u306E\u307F\u51FA\u529B\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n\n-
    \u30B9\u30C6\u30C3\u30D7\u30D0\u30A4\u30B9\u30C6\u30C3\u30D7\u3067\u6B21\u306E\u6D41\u308C\u3067\u51E6\u7406\u3059\u308B\u3053\u3068\u3092\u60F3\u5B9A\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n   
    1. \u30E1\u30C3\u30BB\u30FC\u30B8\u306E\u5185\u5BB9\u3092\u3088\u304F\u8AAD\u307F\u3001\u3069\u306E\u611F\u60C5\uFF08Emotion\u30E9\u30D9\u30EB\uFF09\u304C\u6700\u3082\u5F37\u3044\u304B\u3092\u8003\u5BDF\u3057\u307E\u3059\u3002\n   
    2. \u305D\u306E\u611F\u60C5\u304C\u306A\u305C\u9078\u3070\u308C\u308B\u306E\u304B\u3001\u6839\u62E0\u3092\u5185\u90E8\u3067\u691C\u8A0E\u3057\u3001\u5F37\u3055\uFF080\uFF5E1\u306Efloat\u5024\uFF09\u3082\u3069\u308C\u304F\u3089\u3044\u304B\u601D\u8003\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n   
    3. \u6700\u7D42\u7684\u306A\u51FA\u529B\u306FJSON\u5F62\u5F0F\u3067\u3001\u300Cemotion\u300D\u3068\u300Cstrength\u300D\u3001\u300Cmessage\u300D\u306E3\u3064\u306E\u30AD\u30FC\u3092\u542B\u3081\u3001\u4EE5\u4E0B\u306E\u30D5\u30A9\u30FC\u30DE\u30C3\u30C8\u3067\u51FA\u529B\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n\nEmotion\u30E9\u30D9\u30EB\uFF08\u611F\u60C5\u30AB\u30C6\u30B4\u30EA\uFF09:\n-
    Angry\n- Anticipation\n- Disgust\n- Fear\n- Joy\n- Sadness\n- Surprise\n- Trust\n-
    Thinking\n\nStrength\u30E9\u30D9\u30EB:\n- 0~1\u306E\u5C0F\u6570\uFF08float\uFF09\u3067\u8A18\u8F09\n\n#
    \u51FA\u529B\u30D5\u30A9\u30FC\u30DE\u30C3\u30C8\n\n\u51FA\u529B\u306F\u5FC5\u305AJSON\u5F62\u5F0F\uFF08\u5168\u4F53\u304C\u3072\u3068\u3064\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\uFF09\u3067\u51FA\u529B\u3057\u3066\u304F\u3060\u3055\u3044\u3002\nJSON\u4EE5\u5916\u306E\u6587\u3084\u8AAC\u660E\u306F\u7D76\u5BFE\u306B\u51FA\u529B\u3057\u306A\u3044\u3067\u304F\u3060\u3055\u3044\u3002\n\n{\n   
    \"emotion\": \"<Emotion\u30E9\u30D9\u30EB>\",  // \u5FC5\u305A\u4E0A\u8A18Emotion\u30E9\u30D9\u30EB\u304B\u3089\u3072\u3068\u3064\n   
    \"strength\": <float: 0~1>,      // \u611F\u60C5\u306E\u5F37\u3055\uFF08float\u5024\u3001\u4F8B:
    0.72\uFF09\n    \"message\": \"<\u5165\u529B\u30E1\u30C3\u30BB\u30FC\u30B8\u305D\u306E\u307E\u307E>\"\n}\n\n#
    \u4F8B\n\n\u5165\u529B\u30E1\u30C3\u30BB\u30FC\u30B8: \n\u300C\u3053\u306E\u9593\u306E\u30D7\u30EC\u30BC\u30F3\u306F\u672C\u5F53\u306B\u697D\u3057\u304B\u3063\u305F\u3002\u6B21\u3082\u304C\u3093\u3070\u308B\u305E\uFF01\u300D\n\n\u51FA\u529B\u4F8B:\n{\n   
    \"emotion\": \"Joy\",\n    \"strength\": 0.85,\n    \"message\": \"\u3053\u306E\u9593\u306E\u30D7\u30EC\u30BC\u30F3\u306F\u672C\u5F53\u306B\u697D\u3057\u304B\u3063\u305F\u3002\u6B21\u3082\u304C\u3093\u3070\u308B\u305E\uFF01\"\n}\n\n\u5165\u529B\u30E1\u30C3\u30BB\u30FC\u30B8:\n\u300C\u306A\u3093\u3067\u307E\u305F\u5931\u6557\u3057\u305F\u3093\u3060\u308D\u3046\u3002\u3082\u3063\u3068\u6CE8\u610F\u3059\u308C\u3070\u3088\u304B\u3063\u305F\u3002\u300D\n\n\u51FA\u529B\u4F8B:\n{\n   
    \"emotion\": \"Sadness\",\n    \"strength\": 0.7,\n    \"message\": \"\u306A\u3093\u3067\u307E\u305F\u5931\u6557\u3057\u305F\u3093\u3060\u308D\u3046\u3002\u3082\u3063\u3068\u6CE8\u610F\u3059\u308C\u3070\u3088\u304B\u3063\u305F\u3002\"\n}\n\n#
    \u6CE8\u610F\u4E8B\u9805\n- \u5FC5\u305A\u4E8B\u524D\u306B\u5185\u90E8\u7684\u306A\u63A8\u8AD6\u3084\u601D\u8003\u3092\u884C\u3063\u305F\u4E0A\u3067\u3001\u6700\u5F8C\u306BJSON\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u307F\u3092\u51FA\u529B\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n-
    \u5165\u529B\u6587\u306F\u305D\u306E\u307E\u307E \"message\" \u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u5165\u308C\u3066\u304F\u3060\u3055\u3044\u3002\n-
    \u3069\u306E\u611F\u60C5\u304B\u5224\u65AD\u306B\u8FF7\u3046\u5834\u5408\u306F\u3001\u6700\u3082\u5F37\u3044\u3068\u601D\u308F\u308C\u308B\u3082\u306E\u30921\u3064\u3060\u3051\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n-
    \u51FA\u529B\u3059\u308B\u306E\u306FJSON\u5F62\u5F0F\u306E\u307F\u3067\u3001\u8AAC\u660E\u6587\u3084\u65E5\u672C\u8A9E\u306E\u8AAC\u660E\u306A\u3069\u306F\u7D76\u5BFE\u306B\u66F8\u304B\u306A\u3044\u3067\u304F\u3060\u3055\u3044\u3002"
